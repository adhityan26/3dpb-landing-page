---
export const prerender = false

import BaseLayout from '~/layouts/BaseLayout.astro'
import Navbar from '~/components/Navbar.astro'
import Footer from '~/components/Footer.astro'
import { clientFromEnv, queries, urlFor } from '~/lib/sanity'
import { pickLocalized } from '~/lib/i18n'
import type { SiteSettings, FaceshellCollection } from '~/lib/types'

const client = clientFromEnv()
const [settings, collection] = await Promise.all([
  client.fetch<SiteSettings | null>(queries.siteSettings),
  client.fetch<FaceshellCollection | null>(queries.faceshellCollection),
])

const title = 'Spiderman Faceshell Collection — ' + (pickLocalized(settings?.seo?.defaultTitle, 'id') || '3dprintingbandung')
const description = 'Koleksi Spiderman Faceshell 3D print custom sesuai ukuran kepala. Lihat galeri dan cara pengukuran.'
const logoUrl = settings?.logo ? urlFor(client, settings.logo).height(80).url() : undefined
const logoAlt = settings?.logo?.alt
const ogImageUrl = collection?.items?.[0]?.image
  ? urlFor(client, collection.items[0].image).width(1200).height(630).fit('crop').format('jpg').url()
  : settings?.seo?.ogImage
    ? urlFor(client, settings.seo.ogImage).width(1200).height(630).fit('crop').format('jpg').url()
    : undefined

const headline = pickLocalized(collection?.headline, 'id') || 'Spiderman Faceshell Collection'
const desc = pickLocalized(collection?.description, 'id')
const items = collection?.items ?? []
const guide = collection?.measurementGuide
const guideTitle = pickLocalized(guide?.title, 'id') || 'Cara Pengukuran'
const guideDesc = pickLocalized(guide?.description, 'id')
const steps = guide?.steps ?? []
const waMessage = collection?.orderWhatsappMessage || 'Halo, saya tertarik order Spiderman Faceshell custom.'
const waNumber = settings?.contact?.whatsapp?.replace(/[^0-9]/g, '') || ''
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`

const productJsonLd = items.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Spiderman Faceshell Collection',
  numberOfItems: items.length,
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: pickLocalized(item.title, 'id'),
      image: urlFor(client, item.image).width(800).height(800).fit('crop').format('webp').url(),
    },
  })),
} : undefined
---
<BaseLayout locale="id" title={title} description={description} ogImageUrl={ogImageUrl} canonicalPath="/id/faceshell" jsonLd={productJsonLd ? [productJsonLd] : undefined}>
  <Navbar locale="id" whatsappNumber={settings?.contact?.whatsapp} logoUrl={logoUrl} logoAlt={logoAlt} />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <!-- Hero -->
    <div class="mb-12">
      <h1 class="text-3xl font-display font-bold md:text-5xl">{headline}</h1>
      {desc && <p class="mt-4 max-w-2xl text-[color:var(--color-ink-500)]">{desc}</p>}
    </div>

    <!-- Gallery -->
    {items.length > 0 && (
      <section class="mb-16">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {items.map((item) => (
            <figure class="overflow-hidden rounded-2xl border border-[color:var(--color-ink-100)] bg-white shadow-sm">
              <img
                src={urlFor(client, item.image).width(800).height(800).fit('crop').format('webp').url()}
                alt={item.image.alt ?? (pickLocalized(item.title, 'id') as string)}
                class="aspect-square w-full object-cover"
                loading="lazy"
              />
              <figcaption class="p-4">
                <h3 class="font-display font-semibold">{pickLocalized(item.title, 'id')}</h3>
                {pickLocalized(item.caption, 'id') && (
                  <p class="mt-1 text-sm text-[color:var(--color-ink-500)]">{pickLocalized(item.caption, 'id')}</p>
                )}
              </figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    <!-- Measurement Guide -->
    {steps.length > 0 && (
      <section class="mb-16 rounded-2xl bg-[color:var(--color-ink-100)] p-6 md:p-10">
        <h2 class="mb-2 text-2xl font-display font-bold md:text-3xl">{guideTitle}</h2>
        {guideDesc && <p class="mb-8 text-[color:var(--color-ink-500)]">{guideDesc}</p>}
        <ol class="space-y-6">
          {steps.map((step, i) => (
            <li class="flex gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[color:var(--color-brand-500)] text-sm font-bold text-white">
                {i + 1}
              </span>
              <div class="flex-1">
                <p class="text-sm leading-relaxed">{pickLocalized(step.text, 'id')}</p>
                {step.image && (
                  <img
                    src={urlFor(client, step.image).width(600).format('webp').url()}
                    alt={step.image.alt ?? `Step ${i + 1}`}
                    class="mt-3 max-w-sm rounded-xl"
                    loading="lazy"
                  />
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Order CTA -->
    <section class="rounded-2xl bg-[color:var(--color-ink-900)] p-8 text-center text-white md:p-12">
      <h2 class="text-2xl font-display font-bold md:text-3xl">Tertarik? Pesan Sekarang</h2>
      <p class="mt-2 text-[color:var(--color-ink-300)]">Custom sesuai ukuran kepala kamu. Hubungi kami via WhatsApp.</p>
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="mt-6 inline-block rounded-full bg-[#25D366] px-8 py-3 font-semibold text-white hover:opacity-90"
      >
        Order via WhatsApp
      </a>
    </section>
  </main>
  <Footer locale="id" settings={settings} logoUrl={logoUrl} logoAlt={logoAlt} />
</BaseLayout>
