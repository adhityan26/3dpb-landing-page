---
import '~/styles/global.css'
import type { Locale } from '~/lib/i18n'

interface Props {
  locale: Locale
  title: string
  description: string
  ogImageUrl?: string
  canonicalPath?: string
  jsonLd?: Record<string, unknown>[]
}

const { locale, title, description, ogImageUrl, canonicalPath, jsonLd } = Astro.props
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://3dprintingbandung.my.id'
const cfAnalyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN
const pageUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : `${siteUrl}/${locale}/`
const otherLocale = locale === 'id' ? 'en' : 'id'
const otherPath = canonicalPath ? canonicalPath.replace(`/${locale}/`, `/${otherLocale}/`) : `/${otherLocale}/`
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="3dprintingbandung" />
    <meta property="og:locale" content={locale === 'id' ? 'id_ID' : 'en_US'} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:width" content="1200" />}
    {ogImageUrl && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <link rel="alternate" hreflang="id" href={`${siteUrl}${canonicalPath ?? `/${locale}/`}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${otherPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/id/`} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      '@id': `${siteUrl}/#business`,
      name: '3dprintingbandung',
      url: siteUrl,
      description: 'Studio 3D printing di Bandung. Jual keychain, fidget, cosplay mask/helmet, dan jasa custom 3D print.',
      areaServed: 'Bandung, Indonesia',
      priceRange: 'Rp9.000 - Rp775.000',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bandung',
        addressRegion: 'Jawa Barat',
        addressCountry: 'ID',
      },
      sameAs: [
        'https://shopee.co.id/3dprintingbandung',
      ],
    })} />

    {jsonLd && jsonLd.map((ld) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
    ))}

    <slot name="head" />
  </head>
  <body class="bg-white text-[color:var(--color-ink-900)]">
    <slot />

    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
      />
    )}
  </body>
</html>
