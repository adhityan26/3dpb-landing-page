---
import type { Locale } from '~/lib/i18n'
import { clientFromEnv, urlFor } from '~/lib/sanity'
import type { Testimonial } from '~/lib/types'

interface Props {
  locale: Locale
  testimonials: Testimonial[]
}
const { locale, testimonials } = Astro.props
const client = clientFromEnv()

const title = locale === 'id' ? 'Apa Kata Mereka' : 'What They Say'
---
{testimonials.length > 0 && (
  <section class="mx-auto max-w-6xl px-4 py-20">
    <h2 class="mb-10 text-center text-3xl font-display font-bold md:text-4xl">{title}</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <article class="flex flex-col rounded-2xl border border-[color:var(--color-ink-100)] bg-white p-5 shadow-sm">
          {t.image && (
            <img
              src={urlFor(client, t.image).width(400).height(300).fit('crop').format('webp').url()}
              alt={t.image.alt ?? `Testimonial from ${t.name}`}
              class="mb-4 rounded-xl object-cover w-full aspect-[4/3]"
              loading="lazy"
            />
          )}
          <blockquote class="flex-1 text-sm text-[color:var(--color-ink-600)] leading-relaxed">
            "{t.text}"
          </blockquote>
          <p class="mt-4 text-sm font-semibold">— {t.name}</p>
        </article>
      ))}
    </div>
  </section>
)}
