---
import type { Locale } from '~/lib/i18n'
import { t, pickLocalized } from '~/lib/i18n'
import type { FAQ } from '~/lib/types'

interface Props {
  locale: Locale
  items: FAQ[]
}
const { locale, items } = Astro.props
---
{items.length > 0 && (
  <section class="mx-auto max-w-3xl px-4 py-20">
    <h2 class="mb-10 text-center text-3xl font-display font-bold md:text-4xl">
      {t(locale, 'faq.title')}
    </h2>
    <dl class="divide-y divide-[color:var(--color-ink-100)]">
      {items.map((item) => {
        const question = pickLocalized(item.question, locale) ?? ''
        const answer = pickLocalized(item.answer, locale) ?? ''
        return (
          <div class="faq-item group py-5">
            <dt>
              <button
                type="button"
                class="faq-trigger flex w-full items-start justify-between gap-4 text-left font-semibold text-[color:var(--color-ink-900)]"
                aria-expanded="false"
              >
                <span>{question}</span>
                <svg
                  class="faq-icon mt-0.5 h-5 w-5 shrink-0 text-[color:var(--color-ink-400)] transition-transform duration-200"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </button>
            </dt>
            <dd class="faq-answer mt-0 hidden overflow-hidden text-sm text-[color:var(--color-ink-600)] leading-relaxed">
              <p class="pt-3">{answer}</p>
            </dd>
          </div>
        )
      })}
    </dl>
  </section>
)}

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true'
      btn.setAttribute('aria-expanded', String(!expanded))
      const answer = btn.closest('.faq-item')?.querySelector<HTMLElement>('.faq-answer')
      const icon = btn.querySelector<SVGElement>('.faq-icon')
      if (answer) {
        answer.classList.toggle('hidden', expanded)
      }
      if (icon) {
        icon.classList.toggle('rotate-180', !expanded)
      }
    })
  })
</script>
